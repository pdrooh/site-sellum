# Webhook Clint — URL do endpoint em Integrações > Webhook (não commitar a URL real em código).
CLINT_WEBHOOK_URL=

# Link wa.me ou api.whatsapp.com para a Central de Ajuda (opcional).
NEXT_PUBLIC_WHATSAPP_URL=

# Admin do blog (painel em /admin). Gere um token longo e aleatório para ADMIN_SESSION_TOKEN.
ADMIN_PASSWORD=
ADMIN_SESSION_TOKEN=

# Permite criar/remover artigos e membros via API gravando em disco (dev ou servidor com FS persistente).
ALLOW_BLOG_FS_ADMIN=false
